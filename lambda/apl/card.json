{
  "type": "APL",
  "version": "2023.2",
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "TouchWrapper",
        "width": "100vw",
        "height": "100vh",
        "onPress": [
          {
            "type": "SendEvent",
            "arguments": ["flip"]
          }
        ],
        "item": {
          "type": "Frame",
          "width": "100vw",
          "height": "100vh",
          "backgroundColor": "${payload.cardData.bg}",
          "item": {
            "type": "Container",
            "width": "100vw",
            "height": "100vh",
            "paddingLeft": "6vw",
            "paddingRight": "6vw",
            "paddingTop": "3vh",
            "paddingBottom": "3vh",
            "direction": "column",
            "items": [
              {
                "type": "Container",
                "direction": "row",
                "width": "100%",
                "justifyContent": "spaceBetween",
                "items": [
                  {
                    "type": "Text",
                    "text": "${payload.cardData.deckName}",
                    "fontSize": "24dp",
                    "color": "#FFFFFF",
                    "opacity": 0.6
                  },
                  {
                    "type": "Text",
                    "text": "${payload.cardData.progress}",
                    "fontSize": "24dp",
                    "color": "#FFFFFF",
                    "opacity": 0.6
                  }
                ]
              },
              {
                "type": "Container",
                "grow": 1,
                "width": "100%",
                "direction": "column",
                "justifyContent": "center",
                "alignItems": "center",
                "items": [
                  {
                    "when": "${payload.cardData.video != ''}",
                    "type": "Video",
                    "width": "80vw",
                    "height": "42vh",
                    "source": "${payload.cardData.video}",
                    "autoplay": true,
                    "audioTrack": "none",
                    "repeatCount": -1,
                    "scale": "best-fit"
                  },
                  {
                    "when": "${payload.cardData.video == '' && payload.cardData.image != ''}",
                    "type": "Image",
                    "width": "80vw",
                    "height": "42vh",
                    "source": "${payload.cardData.image}",
                    "scale": "best-fit"
                  },
                  {
                    "type": "Text",
                    "text": "${payload.cardData.text}",
                    "fontSize": "52dp",
                    "fontWeight": "700",
                    "color": "#FFFFFF",
                    "textAlign": "center",
                    "maxLines": 5,
                    "paddingTop": "2vh"
                  }
                ]
              },
              {
                "type": "Text",
                "text": "${payload.cardData.hint}",
                "fontSize": "22dp",
                "color": "#FFFFFF",
                "opacity": 0.45,
                "textAlign": "center"
              }
            ]
          }
        }
      }
    ]
  }
}
